# ── Django core ────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────────────────────────
# Production (Render + Supabase): set DATABASE_URL in the Render dashboard.
# Get it from: Supabase → Project → Settings → Database → Session mode URI
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Local dev: use individual vars below (DATABASE_URL takes priority if set)
DB_NAME=expense_tracker
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production
# e.g. CORS_ALLOWED_ORIGINS=https://myapp.vercel.app,https://myapp.com
# Leave unset in local dev — all origins allowed when DEBUG=True
CORS_ALLOWED_ORIGINS=

# ── Cloudflare R2 (production media storage) ──────────────────────────────────
# Leave unset in local dev — falls back to local filesystem storage
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Email (optional) ───────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
