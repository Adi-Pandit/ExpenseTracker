{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://expense-tracker-api-nyr8.onrender.com/api/$1"
    },
    {
      "src": "/auth/(.*)",
      "dest": "https://expense-tracker-api-nyr8.onrender.com/auth/$1"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "https://expense-tracker-api-nyr8.onrender.com/dashboard/$1"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
